extends layout
block content
  header.bg-white.p-3.shadow-sm.sticky-top.mb-3
    .d-flex.justify-content-between.align-items-center
      p.mb-0
        | Today: 
        strong#current-date(style='color: #00327d;')
      span.badge.bg-info(style='font-size: 0.9rem;') Attendant: #{user.username}
  .row.mb-4
    .col-md-6
      .card.stat-card.text-center
        .card-body
          h6.text-muted.text-uppercase.mb-3 Parked Vehicles
          p #{parkedCount}
          small.text-muted Currently parked
    .col-md-6
      .card.stat-card.text-center
        .card-body
          h6.text-muted.text-uppercase.mb-3 Signed Out Today
          p #{signedOutCount}
          small.text-muted Total: #{totalVehicles} vehicles
  // Attendant Quick Actions
  .card.mb-4
    .card-body
      h2.card-title.mb-4 Attendant Tasks
      .row.g-3
        .col-md-6
          a.btn.btn-primary.w-100.py-3(href='/register-vehicle')
            strong Register New Vehicle
            br
            small.text-white-50 Check in vehicles
        .col-md-6
          a.btn.btn-outline-primary.w-100.py-3(href='/sign-out')
            strong Sign Out Vehicle
            br
            small Check out and payment
        .col-md-6
          a.btn.btn-outline-secondary.w-100.py-3(href='/ tyre-service')
            strong Tyre Services
            br
            small Record tyre services
        .col-md-6
          a.btn.btn-outline-info.w-100.py-3(href='/battery-service')
            strong Battery Services
            br
            small Record battery services
        .col-md-6
          a.btn.btn-dark.w-100.py-3(href='/logout')
            strong Logout
            br
            small Sign out of system