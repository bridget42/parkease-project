extends layout
block content
  .d-flex.justify-content-center.align-items-center.min-vh-100
    .card.shadow-lg.border-0.rounded-4.p-4(style='width: 100%; max-width: 450px;')
      .text-center.mb-4
        h1.fw-bold.text-primary ParkEase
        p.text-muted Create a New User Account
      form(action='/signup' method='POST')
        .mb-3
          label.form-label(for='username') Username
          input.form-control.rounded-3(type='text' name='username')
        .mb-3
          label.form-label(for='password') Password
          input.form-control.rounded-3(type='password' name='password')
        .mb-3
          label.form-label(for='role') Role
          select.form-select.rounded-3(name='role')
            option(value='') Select Role
            option(value='attendant') Attendant
            option(value='admin') Admin
            option(value='manager') Manager
        button.btn.btn-primary.w-100.rounded-3.py-2.fw-semibold(type='submit')
          | Create Account
        .text-center.mt-3
          a.text-decoration-none(href='/') Already have an account? Login
