extends layout
block content
  header.bg-white.p-3.shadow-sm.sticky-top.mb-3
    .d-flex.justify-content-between.align-items-center
      p.mb-0
        | Today: 
        strong#current-date(style='color: #00327d;')
      span.badge.bg-primary(style='font-size: 0.9rem;') Hello #{user.username}
  .row.mb-4
    .col-md-4
      .card.stat-card.text-center
        .card-body
          h6.text-muted.text-uppercase.mb-3 Parked Vehicles
          p #{parkedCount}
          small.text-muted Currently parked
    .col-md-4
      .card.stat-card.text-center
        .card-body
          h6.text-muted.text-uppercase.mb-3 Signed Out Today
          p #{signedOutCount}
          small.text-muted Total: #{totalVehicles} vehicles
    .col-md-4
      .card.stat-card.text-center
        .card-body
          h6.text-muted.text-uppercase.mb-3 Today's Revenue
          p UGX #{todayRevenue.toLocaleString()}
          small.text-muted From #{totalVehicles} transactions
  // Quick Actions
  .card.mb-4
    .card-body
      h2.card-title.mb-4 Quick Actions
      .row.g-3
        .col-md-6
          a.btn.btn-primary.w-100.py-3(href='/register-vehicle')
            strong Register New Vehicle
            br
            //- small.text-white-50 Add vehicles to parking
        .col-md-6
          a.btn.btn-outline-primary.w-100.py-3(href='/sign-out')
            strong Sign Out Vehicle
            br
            //- small Complete exit and payment
        .col-md-6
          a.btn.btn-outline-secondary.w-100.py-3(href='/tyre-service')
            strong Tyre Services
            br
            //- small Record maintenance services
        .col-md-6
          a.btn.btn-outline-info.w-100.py-3(href='/reports')
            strong View Reports
            br
            small Daily revenue & analytics
  // Currently Parked Vehicles
  .row.g-4
    .col-md-6
      .card
        .card-header.bg-light
          h5.mb-0 Currently Parked (#{vehicles.length})
        .table-responsive
          table.table.mb-0
            thead
              tr
                th Plate
                th Type
                th Driver
                th Slot
                th Time
            tbody
              if vehicles.length > 0
                each vehicle in vehicles
                  tr
                    td #{vehicle.plateNumber}
                    td #{vehicle.vehicleType}
                    td #{vehicle.driverName}
                    td #{vehicle.parkingSlot}
                    td #{new Date(vehicle.entryTime).toLocaleTimeString()}
              else
                tr
                  td(colspan='5').text-center.text-muted No vehicles currently parked
    .col-md-6
      .card
        .card-header.bg-light
          h5.mb-0 Recent Vehicles
        .table-responsive
          table.table.mb-0
            thead
              tr
                th Plate
                th Type
                th Status
                th Fee
            tbody
              if recentVehicles.length > 0
                each vehicle in recentVehicles
                  tr
                    td #{vehicle.plateNumber}
                    td #{vehicle.vehicleType}
                    td 
                      span.badge.bg-success= vehicle.status
                    td UGX #{vehicle.parkingFee.toLocaleString()}
              else
                tr
                  td(colspan='4').text-center.text-muted No recent vehicles
  script(src='/js/attendant-dashboard.js')
